{
  "redact_private_values": true,
  "when_closing_with_no_tabs": "keep_window_open",
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "tab_size": 2,
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "show_edit_predictions": false,
  "agent": {
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "always",
    "single_file_review": true,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "git diff"
            },
            {
              "pattern": "git log"
            },
            {
              "pattern": "git show"
            },
            {
              "pattern": "cargo build"
            },
            {
              "pattern": "cargo test"
            },
            {
              "pattern": "cargo clippy"
            },
            {
              "pattern": "grep"
            },
            {
              "pattern": "cargo fmt"
            },
            {
              "pattern": "head"
            },
            {
              "pattern": "tail"
            }
          ],
          "always_deny": [
            {
              "pattern": "sudo"
            },
            {
              "pattern": "su"
            }
          ]
        }
      }
    }
  },
  "base_keymap": "VSCode",
  "show_whitespaces": "all",
  "theme": {
    "light": "Catppuccin Latte",
    "dark": "VSCode Dark Modern"
  },
  "icon_theme": {
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "wrap_guides": [80],
  "file_types": {
    "Helm": ["**/helmfile.d/**/*.yaml", "**/*.gotmpl", "**/*.tmpl"],
    "Dockerfile": ["Dockerfile*"],
    "JSON": [".prettierrc"]
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "codebook": true,
    "dockerfile": true,
    "docker-compose": false,
    "html": true,
    "ini": true,
    "git-firefly": true,
    "helm": true,
    "java": true,
    "just": true,
    "lua": true,
    "make": true,
    "one-dark-pro": true,
    "php": true,
    "prisma": true,
    "pylsp": true,
    "ruby": true,
    "sql": true,
    "svelte": true,
    "terraform": true,
    "tombi": true,
    "toml": true,
    "vscode-dark-modern": true
  },
  "format_on_save": "on",
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    },
    "vtsls": {
      "settings": {
        "javascript": {
          "preferences": {
            "importModuleSpecifier": "relative"
          }
        },
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "relative"
          }
        }
      }
    }
  }
}
